# Database Configuration
MYSQL_DATABASE=taskmanager
MYSQL_ROOT_PASSWORD=your_root_password
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/taskmanager?allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_root_password

# Security
JWT_SECRET=your_secret_key_at_least_32_chars
JWT_EXPIRATION_MS=86400000

# CI/CD & External Services
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_token
SONAR_TOKEN=your_sonarqube_token
GITHUB_TOKEN=your_github_token
